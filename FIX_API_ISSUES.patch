#!/usr/bin/env python3
import re

def fix_excel_set_formula():
    with open('src/excel_mcp_server_fastmcp/server.py', 'r') as f:
        content = f.read()

    # 查找并修复 excel_set_formula 函数
    pattern = r'(def excel_set_formula\([^)]+\)[^:]*:[^"]*"[^"]*"\n)(\s+_path_err)'
